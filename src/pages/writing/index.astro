---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../config/site';

const allPosts = (await getCollection('writing'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group posts by year
const postsByYear = new Map<number, typeof allPosts>();
for (const post of allPosts) {
  const year = post.data.date.getFullYear();
  if (!postsByYear.has(year)) {
    postsByYear.set(year, []);
  }
  postsByYear.get(year)!.push(post);
}

// Sort years descending
const years = [...postsByYear.keys()].sort((a, b) => b - a);

function formatDate(date: Date): string {
  return date.toISOString().slice(0, 10);
}
---

<BaseLayout title={`Writing — ${SITE.name}`} description={`Devlogs and technical writing by ${SITE.name}.`}>
  <div class="container page">
    <h1 class="section-label">writing/</h1>
    <hr class="section-divider" />

    {years.length > 0 ? (
      <div class="years">
        {years.map((year) => (
          <section class="year-group" aria-label={`Posts from ${year}`}>
            <h2 class="year-label">{year}</h2>
            <ul class="post-list" role="list">
              {postsByYear.get(year)!.map((post) => (
                <li>
                  <a href={`/writing/${post.id}`} class="post-row">
                    <time class="post-date" datetime={formatDate(post.data.date)}>
                      {formatDate(post.data.date)}
                    </time>
                    <span class="post-title">{post.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    ) : (
      <p class="empty-state">no posts yet — first one coming soon</p>
    )}
  </div>
</BaseLayout>

<style>
  .page {
    padding: 64px 24px var(--section-gap);
  }

  .years {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .year-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 20px;
    font-weight: 400;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .post-row {
    display: flex;
    align-items: baseline;
    gap: 20px;
    text-decoration: none;
    padding: 4px 0;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-muted);
    min-width: 100px;
    flex-shrink: 0;
  }

  .post-title {
    font-size: 16px;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .post-row:hover .post-title {
    color: var(--accent);
  }

  .empty-state {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .post-row {
      flex-direction: column;
      gap: 4px;
    }

    .post-date {
      min-width: auto;
    }
  }
</style>
