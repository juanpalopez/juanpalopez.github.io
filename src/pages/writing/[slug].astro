---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get other recent posts for "More writing" section
const allPosts = (await getCollection('writing'))
  .filter((p) => !p.data.draft && p.id !== post.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toISOString().slice(0, 10);
}

// Estimate reading time (~200 words per minute)
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));
---

<BaseLayout title={`${post.data.title} — Juan Lopez`} description={post.data.title}>
  <article class="container page">
    <!-- Breadcrumb -->
    <p class="breadcrumb">
      <a href="/writing">writing</a> / {formatDate(post.data.date)}
    </p>
    <hr class="section-divider" />

    <!-- Post header -->
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-meta">
        Juan Lopez &middot; {formatDate(post.data.date)} &middot; {readingTime} min read
      </p>
    </header>

    <hr class="content-divider" />

    <!-- Post body -->
    <div class="prose">
      <Content />
    </div>

    <hr class="content-divider" />

    <!-- Author card -->
    <div class="author-card card">
      <div class="author-info">
        <div class="author-avatar" aria-hidden="true">JL</div>
        <div>
          <p class="author-name">Juan Lopez</p>
          <p class="author-bio">Backend developer. Building in public.</p>
        </div>
      </div>
      <a href="/" class="author-link">
        &rarr; juanpalopez.github.io
      </a>
    </div>

    <!-- More writing -->
    {allPosts.length > 0 && (
      <section class="more-writing" aria-labelledby="more-writing-heading">
        <h2 id="more-writing-heading" class="more-heading">More writing</h2>
        <ul class="more-list" role="list">
          {allPosts.map((p) => (
            <li>
              <a href={`/writing/${p.id}`} class="more-row">
                <time class="more-date" datetime={formatDate(p.data.date)}>
                  {formatDate(p.data.date)}
                </time>
                <span class="more-title">{p.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .page {
    padding: 64px 24px var(--section-gap);
  }

  /* --- Breadcrumb --- */
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  /* --- Post header --- */
  .post-header {
    margin-bottom: 0;
  }

  .post-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-muted);
  }

  .content-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }

  /* --- Author card --- */
  .author-card {
    margin-top: 48px;
    padding: 20px;
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .author-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .author-bio {
    font-size: 13px;
    color: var(--text-secondary);
  }

  .author-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    transition: color var(--transition-fast);
  }

  .author-link:hover {
    color: var(--accent-hover);
  }

  /* --- More writing --- */
  .more-writing {
    margin-top: 48px;
  }

  .more-heading {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 400;
    margin-bottom: 20px;
  }

  .more-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .more-row {
    display: flex;
    align-items: baseline;
    gap: 20px;
    text-decoration: none;
    padding: 4px 0;
  }

  .more-date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-muted);
    min-width: 100px;
    flex-shrink: 0;
  }

  .more-title {
    font-size: 16px;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .more-row:hover .more-title {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 24px;
    }

    .more-row {
      flex-direction: column;
      gap: 4px;
    }

    .more-date {
      min-width: auto;
    }
  }
</style>
